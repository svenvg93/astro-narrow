---
import { Icon } from 'astro-icon/components';
import type { CollectionEntry } from 'astro:content';
import type { Locale } from '../../config/i18n';
import type { ContentTypeId } from '../../config/content';
import { siteConfig } from '../../config/site';
import EntryList from '../content/EntryList.astro';
import ViewAll from '../ui/ViewAll.astro';

interface HomeSection {
  id: ContentTypeId;
  title: string;
  href: string;
  entries: Array<CollectionEntry<any>>;
}

interface Props {
  locale: Locale;
  sections: HomeSection[];
}

const { locale, sections } = Astro.props;
const { author } = siteConfig;

function assetPath(path: string) {
  if (/^(https?:)?\/\//.test(path) || path.startsWith('data:')) return path;
  const base = import.meta.env.BASE_URL || '/';
  return `${base.replace(/\/?$/, '/')}${path.replace(/^\//, '')}`;
}

const avatarSrc = assetPath(author.avatar);
---

<section class="py-8 sm:py-10">
  <div class="profile-card surface-card px-7 py-5 sm:px-8 sm:py-6">
    <div class="flex flex-col items-center gap-6 text-center md:flex-row md:items-start md:text-left">
      <img
        src={avatarSrc}
        alt={author.name}
        class="h-24 w-24 shrink-0 rounded-full border-4 border-primary/20 object-cover shadow-sm"
      />

      <div class="min-w-0 flex-1">
        <h1 class="text-3xl font-bold tracking-tight">{author.name}</h1>
        <p class="mt-1.5 text-lg text-muted-foreground">{author.title[locale]}</p>
        <p class="mt-3 leading-relaxed text-foreground">{author.description[locale]}</p>

        {author.social.length > 0 && (
          <div class="mt-5 flex flex-wrap items-center justify-center gap-2.5 md:justify-start">
            {author.social.map((item) => (
              <a
                href={item.url}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 rounded-[var(--radius-control)] bg-muted px-3 py-2 text-sm font-medium text-muted-foreground transition-all duration-300 ease-out hover:-translate-y-0.5 hover:bg-primary/10 hover:text-primary"
                title={item.name}
              >
                <Icon name={item.icon} class="h-4 w-4" />
                <span>{item.name}</span>
              </a>
            ))}
          </div>
        )}
      </div>
    </div>
  </div>
</section>

{sections.map((section) => (
  section.entries.length > 0 && (
    <section class="py-8">
      <div class="mb-3 flex items-end justify-between gap-4">
        <h2 class="text-2xl font-semibold">{section.title}</h2>
        <ViewAll href={section.href} locale={locale} />
      </div>
      <EntryList entries={section.entries} collection={section.id} locale={locale} />
    </section>
  )
))}
