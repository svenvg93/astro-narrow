---
import { Icon } from 'astro-icon/components';
import type { Locale } from '../../config/i18n';
import { useTranslations } from '../../i18n/utils';

interface Props {
  href: string;
  locale: Locale;
  label?: string;
}

const { href, locale, label } = Astro.props;
const t = useTranslations(locale);
---

<a
  href={href}
  class="group inline-flex min-h-9 items-center gap-1.5 rounded-[var(--radius-control)] px-3 py-1.5 text-sm font-medium text-muted-foreground transition-colors duration-200 hover:bg-accent hover:text-accent-foreground"
>
  <span>{label ?? t('home.viewAll')}</span>
  <Icon name="lucide:arrow-right" class="h-4 w-4 transition-transform duration-200 group-hover:translate-x-0.5" />
</a>
