---
import { Icon } from 'astro-icon/components';
import type { Locale } from '../../config/i18n';
import { archiveFilterPath, formatDate } from '../../lib/content/entries';
import { useTranslations } from '../../i18n/utils';

interface Props {
  title: string;
  description?: string;
  date?: Date;
  locale: Locale;
  categories?: string[];
  tags?: string[];
  series?: {
    title: string;
    href: string;
    position: number;
    total: number;
  };
}

const {
  title,
  description,
  date,
  locale,
  categories = [],
  tags = [],
  series
} = Astro.props;

const t = useTranslations(locale);
const taxonomyGroups = [
  { label: t('archive.filter.categories'), filter: 'category', prefix: '', terms: categories },
  { label: t('archive.filter.tags'), filter: 'tag', prefix: '#', terms: tags }
] as const;
const hasTaxonomy = taxonomyGroups.some((group) => group.terms.length > 0);
---

<header class="mb-10">
  {series && (
    <a
      href={series.href}
      class="mb-3 inline-flex min-h-8 flex-wrap items-center gap-1.5 rounded-[var(--radius-control)] text-xs font-medium text-muted-foreground transition-colors duration-200 hover:text-primary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/35 motion-reduce:transition-none"
    >
      <Icon name="lucide:list-ordered" class="h-3.5 w-3.5" />
      <span class="uppercase tracking-[0.14em]">{t('series.label')}</span>
      <span aria-hidden="true">·</span>
      <span class="text-foreground">{series.title}</span>
      <span aria-hidden="true">·</span>
      <span class="tabular-nums">{series.position} / {series.total}</span>
    </a>
  )}
  <h1 class="text-3xl font-bold leading-tight tracking-tight sm:text-4xl">{title}</h1>
  {description && <p class="mt-4 text-lg leading-relaxed text-muted-foreground">{description}</p>}

  <div class="surface-panel mt-6 p-5 text-sm">
    <div class="flex flex-wrap items-center gap-x-5 gap-y-2 text-muted-foreground">
      {date && date.getTime() > 0 && (
        <span class="inline-flex items-center gap-1.5">
          <Icon name="lucide:calendar" class="h-4 w-4" />
          <time datetime={date.toISOString()}>{formatDate(date, locale)}</time>
        </span>
      )}
    </div>

    {hasTaxonomy && (
      <div class="mt-4 space-y-3 border-t border-border pt-4 text-sm">
        {taxonomyGroups.filter((group) => group.terms.length > 0).map((group) => (
          <div class="grid gap-2 sm:grid-cols-[6rem_minmax(0,1fr)] sm:items-start">
            <span class="pt-1.5 font-medium text-muted-foreground">{group.label}</span>
            <div class="flex flex-wrap gap-2">
              {group.terms.map((term) => (
                <a
                  href={archiveFilterPath(locale, group.filter, term)}
                  class="rounded-full bg-muted px-3 py-1.5 text-muted-foreground transition-colors duration-200 hover:bg-primary/10 hover:text-primary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/35 motion-reduce:transition-none"
                >
                  {group.prefix}{term}
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>
    )}
  </div>
</header>
