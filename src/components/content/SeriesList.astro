---
import { Icon } from 'astro-icon/components';
import type { Locale } from '../../config/i18n';
import { formatDate } from '../../lib/content/entries';
import { localizedSeriesPath, type ResolvedSeries } from '../../lib/content/series';
import { useTranslations } from '../../i18n/utils';

interface Props {
  series: ResolvedSeries[];
  locale: Locale;
}

const { series, locale } = Astro.props;
const t = useTranslations(locale);
---

{series.length > 0 ? (
  <div class="surface-panel divide-y divide-border overflow-hidden">
    {series.map((item) => (
      <a
        href={localizedSeriesPath(item.entry)}
        class="group grid min-h-24 gap-4 p-4 transition-colors duration-200 hover:bg-accent focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-inset focus-visible:ring-primary/35 motion-reduce:transition-none sm:grid-cols-[2.5rem_minmax(0,1fr)_auto] sm:items-center sm:p-5"
      >
        <span class="grid h-10 w-10 place-items-center rounded-full border border-border bg-muted text-muted-foreground group-hover:text-primary">
          <Icon name="lucide:list-ordered" class="h-4 w-4" />
        </span>
        <span class="min-w-0">
          <strong class="block text-base font-semibold text-foreground group-hover:text-primary">{item.entry.data.title}</strong>
          {item.entry.data.description && (
            <span class="mt-1 line-clamp-2 block text-sm leading-6 text-muted-foreground">{item.entry.data.description}</span>
          )}
          <span class="mt-2 flex flex-wrap items-center gap-x-3 gap-y-1 text-xs text-muted-foreground">
            <span>{item.chapters.length} {t('series.chapterCount')}</span>
            <span>{t('series.latestChapter')} {formatDate(item.latestChapterDate, locale)}</span>
          </span>
        </span>
        <Icon name="lucide:arrow-right" class="hidden h-4 w-4 text-muted-foreground transition-transform duration-200 group-hover:translate-x-1 group-hover:text-primary motion-reduce:transition-none sm:block" />
      </a>
    ))}
  </div>
) : (
  <p class="surface-panel p-5 text-sm text-muted-foreground">{t('series.empty')}</p>
)}
