---
import { Icon } from 'astro-icon/components';
import type { CollectionEntry } from 'astro:content';
import { localizedEntryPath } from '../../lib/content/entries';
import type { Locale } from '../../config/i18n';
import { useTranslations } from '../../i18n/utils';

interface Props {
  previous?: CollectionEntry<'posts'>;
  next?: CollectionEntry<'posts'>;
  locale: Locale;
  kind?: 'post' | 'series';
}

const { previous, next, locale, kind = 'post' } = Astro.props;
const t = useTranslations(locale);
const previousLabel = kind === 'series' ? t('series.previousChapter') : t('postNav.previous');
const nextLabel = kind === 'series' ? t('series.nextChapter') : t('postNav.next');
const ariaLabel = kind === 'series' ? t('series.navigation') : t('postNav.navigation');
---

{(previous || next) && (
  <nav class="mt-12 grid gap-3 border-t border-border pt-8 sm:grid-cols-2" aria-label={ariaLabel}>
    {previous ? (
      <a href={localizedEntryPath('posts', previous as any)} class="rounded-lg border border-border p-4 hover:bg-accent">
        <span class="flex items-center gap-2 text-sm text-muted-foreground"><Icon name="lucide:arrow-left" class="h-4 w-4" /> {previousLabel}</span>
        <strong class="mt-2 block">{previous.data.title}</strong>
      </a>
    ) : <span></span>}
    {next && (
      <a href={localizedEntryPath('posts', next as any)} class="rounded-lg border border-border p-4 text-right hover:bg-accent">
        <span class="flex items-center justify-end gap-2 text-sm text-muted-foreground">{nextLabel} <Icon name="lucide:arrow-right" class="h-4 w-4" /></span>
        <strong class="mt-2 block">{next.data.title}</strong>
      </a>
    )}
  </nav>
)}
