---
import { Icon } from 'astro-icon/components';
import type { Locale } from '../../config/i18n';
import { useTranslations } from '../../i18n/utils';

interface Experience {
  company: string;
  title: string;
  location?: string;
  start: string;
  end: string;
  description?: string;
  highlights?: string[];
  stack?: string[];
}

interface Education {
  institution: string;
  degree: string;
  location?: string;
  start: string;
  end: string;
  description?: string;
}

interface SkillGroup {
  category: string;
  items: string[];
}

interface Certification {
  name: string;
  issuer: string;
  date?: string;
  url?: string;
}

interface LanguageEntry {
  language: string;
  level: string;
}

interface Props {
  data: {
    title: string;
    name?: string;
    jobTitle?: string;
    location?: string;
    email?: string;
    phone?: string;
    website?: string;
    linkedin?: string;
    github?: string;
    summary?: string;
    experience?: Experience[];
    education?: Education[];
    skills?: SkillGroup[];
    certifications?: Certification[];
    languages?: LanguageEntry[];
  };
  locale: Locale;
}

const { data, locale } = Astro.props;
const t = useTranslations(locale);

const displayName = data.name ?? data.title;
const websiteLabel = data.website?.replace(/^https?:\/\//, '');
const githubLabel = data.github?.replace(/^https?:\/\/github\.com\//, '');
const linkedinLabel = data.linkedin?.replace(/^https?:\/\/(www\.)?linkedin\.com\/in\//, '');

const hasCertifications = Boolean(data.certifications?.length);
const hasLanguages = Boolean(data.languages?.length);
---

<article class="py-6">
  <header class="mb-8">
    <h1 class="mb-1 text-3xl font-bold text-foreground md:text-4xl">{displayName}</h1>
    {data.jobTitle && <p class="mb-3 text-lg font-medium text-primary">{data.jobTitle}</p>}
    <div class="flex flex-wrap gap-x-4 gap-y-1 text-sm text-muted-foreground">
      {data.location && (
        <span class="flex items-center gap-1">
          <Icon name="lucide:map-pin" class="h-3.5 w-3.5" />
          {data.location}
        </span>
      )}
      {data.email && (
        <a href={`mailto:${data.email}`} class="flex items-center gap-1 transition-colors hover:text-primary">
          <Icon name="lucide:mail" class="h-3.5 w-3.5" />
          {data.email}
        </a>
      )}
      {data.phone && (
        <a href={`tel:${data.phone.replace(/\s+/g, '')}`} class="flex items-center gap-1 transition-colors hover:text-primary">
          <Icon name="lucide:phone" class="h-3.5 w-3.5" />
          {data.phone}
        </a>
      )}
      {data.website && (
        <a href={data.website} target="_blank" rel="noopener noreferrer" class="flex items-center gap-1 transition-colors hover:text-primary">
          <Icon name="lucide:external-link" class="h-3.5 w-3.5" />
          {websiteLabel}
        </a>
      )}
      {data.github && (
        <a href={data.github} target="_blank" rel="noopener noreferrer" class="flex items-center gap-1 transition-colors hover:text-primary">
          <Icon name="simple-icons:github" class="h-3.5 w-3.5" />
          {githubLabel}
        </a>
      )}
      {data.linkedin && (
        <a href={data.linkedin} target="_blank" rel="noopener noreferrer" class="flex items-center gap-1 transition-colors hover:text-primary">
          <Icon name="simple-icons:linkedin" class="h-3.5 w-3.5" />
          {linkedinLabel}
        </a>
      )}
    </div>
  </header>

  {data.summary && (
    <section class="mb-8">
      <div class="rounded-lg border border-border bg-card p-6 shadow-sm">
        <p class="leading-relaxed text-foreground">{data.summary}</p>
      </div>
    </section>
  )}

  {data.experience && data.experience.length > 0 && (
    <section class="mb-8">
      <h2 class="mb-4 flex items-center gap-2 text-xl font-bold text-foreground">
        <Icon name="lucide:briefcase" class="h-5 w-5" />
        {t('resume.experience')}
      </h2>
      <div class="space-y-4">
        {data.experience.map((entry) => (
          <div class="rounded-lg border border-border bg-card p-6 shadow-sm">
            <div class="mb-3 flex flex-col gap-1 sm:flex-row sm:items-start sm:justify-between">
              <div class="flex-1">
                <h3 class="font-semibold text-foreground">{entry.title}</h3>
                <p class="text-sm font-medium text-primary">{entry.company}</p>
                {entry.location && <p class="text-xs text-muted-foreground">{entry.location}</p>}
              </div>
              <div class="shrink-0 text-sm text-muted-foreground">{entry.start} – {entry.end}</div>
            </div>
            {entry.description && <p class="mb-3 text-sm leading-relaxed text-foreground">{entry.description}</p>}
            {entry.highlights && entry.highlights.length > 0 && (
              <ul class="space-y-1">
                {entry.highlights.map((highlight) => (
                  <li class="flex items-baseline gap-2 text-sm text-muted-foreground">
                    <span class="shrink-0 text-primary">▸</span>
                    {highlight}
                  </li>
                ))}
              </ul>
            )}
            {entry.stack && entry.stack.length > 0 && (
              <div class="mt-3 flex flex-wrap gap-1.5">
                {entry.stack.map((item) => (
                  <span class="rounded-md bg-primary/10 px-2 py-0.5 text-xs font-medium text-primary">{item}</span>
                ))}
              </div>
            )}
          </div>
        ))}
      </div>
    </section>
  )}

  {data.education && data.education.length > 0 && (
    <section class="mb-8">
      <h2 class="mb-4 flex items-center gap-2 text-xl font-bold text-foreground">
        <Icon name="lucide:book-open" class="h-5 w-5" />
        {t('resume.education')}
      </h2>
      <div class="space-y-4">
        {data.education.map((entry) => (
          <div class="rounded-lg border border-border bg-card p-6 shadow-sm">
            <div class="flex flex-col gap-1 sm:flex-row sm:items-start sm:justify-between">
              <div class="flex-1">
                <h3 class="font-semibold text-foreground">{entry.degree}</h3>
                <p class="text-sm font-medium text-primary">{entry.institution}</p>
                {entry.location && <p class="text-xs text-muted-foreground">{entry.location}</p>}
                {entry.description && <p class="mt-2 text-sm text-muted-foreground">{entry.description}</p>}
              </div>
              <div class="shrink-0 text-sm text-muted-foreground">{entry.start} – {entry.end}</div>
            </div>
          </div>
        ))}
      </div>
    </section>
  )}

  {data.skills && data.skills.length > 0 && (
    <section class="mb-8">
      <h2 class="mb-4 flex items-center gap-2 text-xl font-bold text-foreground">
        <Icon name="lucide:star" class="h-5 w-5" />
        {t('resume.skills')}
      </h2>
      <div class="rounded-lg border border-border bg-card p-6 shadow-sm">
        <div class="space-y-3">
          {data.skills.map((group) => (
            <div class="flex flex-wrap items-baseline gap-2">
              <span class="w-28 shrink-0 text-sm font-medium text-muted-foreground">{group.category}</span>
              <div class="flex flex-wrap gap-2">
                {group.items.map((item) => (
                  <span class="rounded-md bg-muted px-2.5 py-0.5 text-sm font-medium text-foreground">{item}</span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  {(hasCertifications || hasLanguages) && (
    <div class="mb-8 grid grid-cols-1 gap-4 md:grid-cols-2">
      {hasCertifications && (
        <section class="flex flex-col">
          <h2 class="mb-4 flex items-center gap-2 text-xl font-bold text-foreground">
            <Icon name="lucide:file-text" class="h-5 w-5" />
            {t('resume.certifications')}
          </h2>
          <div class="flex-1 rounded-lg border border-border bg-card p-6 shadow-sm">
            <ul class="space-y-3">
              {data.certifications!.map((cert) => (
                <li>
                  {cert.url
                    ? <a href={cert.url} target="_blank" rel="noopener noreferrer" class="font-medium text-foreground transition-colors hover:text-primary">{cert.name}</a>
                    : <span class="font-medium text-foreground">{cert.name}</span>}
                  <p class="text-sm text-muted-foreground">{cert.issuer}{cert.date && ` · ${cert.date}`}</p>
                </li>
              ))}
            </ul>
          </div>
        </section>
      )}

      {hasLanguages && (
        <section class="flex flex-col">
          <h2 class="mb-4 flex items-center gap-2 text-xl font-bold text-foreground">
            <Icon name="lucide:languages" class="h-5 w-5" />
            {t('resume.languages')}
          </h2>
          <div class="flex-1 rounded-lg border border-border bg-card p-6 shadow-sm">
            <ul class="space-y-2">
              {data.languages!.map((lang) => (
                <li class="flex items-center justify-between">
                  <span class="font-medium text-foreground">{lang.language}</span>
                  <span class="text-sm text-muted-foreground">{lang.level}</span>
                </li>
              ))}
            </ul>
          </div>
        </section>
      )}
    </div>
  )}
</article>
