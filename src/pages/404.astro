---
import BaseLayout from '../components/layout/BaseLayout.astro';
import { getLocalePath } from '../config/i18n';
import { useTranslations } from '../i18n/utils';

const locale = 'en';
const t = useTranslations(locale);
const homeHref = getLocalePath(locale, '/');
---

<BaseLayout title="404" description={t('notFound.title')} locale={locale}>
  <section class="py-20">
    <p class="text-sm font-medium text-primary">404</p>
    <h1 class="mt-3 text-4xl font-bold">{t('notFound.title')}</h1>
    <p class="mt-4 text-muted-foreground">{t('notFound.description')}</p>
    <a href={homeHref} class="mt-8 inline-flex rounded-[var(--radius-control)] bg-primary px-4 py-2 text-primary-foreground">{t('notFound.action')}</a>
  </section>
</BaseLayout>
