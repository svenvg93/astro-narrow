---
import { render } from 'astro:content';
import BaseLayout from '../components/layout/BaseLayout.astro';
import PageHeader from '../components/content/PageHeader.astro';
import Resume from '../components/content/Resume.astro';
import { getLocalizedEntries, entrySlug } from '../lib/content/entries';

export async function getStaticPaths() {
  const pages = await getLocalizedEntries('pages', 'en');
  return pages.map((entry) => ({ params: { slug: entrySlug(entry as any) }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
const isTimeline = entry.data.layout === 'timeline';
const isResume = entry.data.layout === 'resume';
---

<BaseLayout title={entry.data.title} description={entry.data.description} locale="en" headings={headings} toc={entry.data.toc ?? (headings.length > 0 ? 'side' : false)} comments={entry.data.comments}>
  {isResume
    ? <Resume data={entry.data} locale="en" />
    : <PageHeader title={entry.data.title} description={entry.data.description} date={entry.data.pubDate} locale="en" />}
  <article class:list={['prose mb-12 max-w-none', { 'timeline-prose': isTimeline }]}>
    <Content />
  </article>
</BaseLayout>
